<!doctype html>
<html>
<head>
  <meta http-equiv="x-ua-compatible" content="IE=11">
  <meta charset="utf-8">
  <title>Codex Fast Toggle</title>
  <hta:application
    id="CodexFastToggle"
    applicationname="Codex Fast Toggle"
    border="thin"
    borderstyle="normal"
    caption="yes"
    contextmenu="no"
    icon="%TEMP%\CodexFastToggle.ico"
    maximizebutton="no"
    minimizebutton="yes"
    scroll="no"
    singleinstance="yes"
    sysmenu="yes"
    windowstate="normal"
  />
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      background: #eef3f8;
      color: #142033;
    }
    .wrap {
      padding: 18px;
      width: 444px;
    }
    .hero {
      padding: 16px;
      border: 1px solid #d7e1eb;
      border-radius: 8px;
      background: #ffffff;
      box-shadow: 0 10px 30px rgba(16, 32, 55, 0.10);
      margin-bottom: 14px;
    }
    .header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .appIcon {
      width: 58px;
      height: 58px;
      border-radius: 14px;
      box-shadow: 0 8px 18px rgba(13, 23, 38, 0.25);
    }
    h1 {
      margin: 0;
      font-size: 20px;
      font-weight: 650;
      line-height: 1.15;
    }
    .sub {
      margin-top: 4px;
      font-size: 12px;
      color: #5b6b7c;
    }
    .status {
      padding: 12px 14px;
      border: 1px solid #cfdbe7;
      background: #f8fbff;
      border-radius: 8px;
      margin-bottom: 12px;
      font-size: 14px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
    }
    .status strong {
      font-size: 18px;
    }
    .row {
      display: flex;
      gap: 8px;
      margin-bottom: 10px;
    }
    button {
      height: 34px;
      padding: 0 12px;
      border: 1px solid #a8b6c5;
      border-radius: 6px;
      background: #fff;
      color: #142033;
      font-size: 13px;
      cursor: pointer;
    }
    button.primary {
      background: #1268e3;
      border-color: #1268e3;
      color: #fff;
      font-weight: 600;
    }
    label {
      display: block;
      margin: 8px 0 12px;
      font-size: 13px;
    }
    pre {
      height: 112px;
      overflow: auto;
      margin: 0;
      padding: 10px;
      border: 1px solid #1b2a3d;
      border-radius: 8px;
      background: #08111e;
      color: #d7e1ef;
      font-family: Consolas, monospace;
      font-size: 12px;
      white-space: pre-wrap;
    }
  </style>
  <script language="JScript">
    var fso = new ActiveXObject("Scripting.FileSystemObject");
    var shell = new ActiveXObject("WScript.Shell");
    var userProfile = shell.ExpandEnvironmentStrings("%USERPROFILE%");
    var systemRoot = envOr("SystemRoot", "C:\\Windows");
    var localAppData = shell.ExpandEnvironmentStrings("%LOCALAPPDATA%");
    var programFiles = shell.ExpandEnvironmentStrings("%PROGRAMFILES%");
    var programFilesX86 = shell.ExpandEnvironmentStrings("%PROGRAMFILES(X86)%");
    var codexHome = envOr("CODEX_HOME", fso.BuildPath(userProfile, ".codex"));
    var codexExeOverride = envOr("CODEX_EXE", "");
    var statePath = fso.BuildPath(codexHome, ".codex-global-state.json");
    var stateBackupPath = fso.BuildPath(codexHome, ".codex-global-state.json.bak");
    var backupDir = fso.BuildPath(codexHome, "fast-toggle-backups");
    var windowIconBase64 = "";
    var headerIconBase64 = "";

    window.resizeTo(494, 428);

    function envOr(name, fallback) {
      var value = shell.ExpandEnvironmentStrings("%" + name + "%");
      if (!value || value === "%" + name + "%") return fallback;
      return value;
    }

    function log(message) {
      var box = document.getElementById("log");
      var now = new Date();
      var stamp = pad2(now.getHours()) + ":" + pad2(now.getMinutes()) + ":" + pad2(now.getSeconds());
      box.innerText += "[" + stamp + "] " + message + "\n";
      box.scrollTop = box.scrollHeight;
    }

    function pad2(n) {
      return n < 10 ? "0" + n : "" + n;
    }

    function setupIcons() {
      try {
        document.getElementById("appIcon").src = "data:image/png;base64," + headerIconBase64;
      } catch (e) {
      }
      try {
        runRuntime("WriteIcon", false, false);
        var iconPath = tempPath("CodexFastToggle.ico");
        document.getElementById("CodexFastToggle").icon = iconPath;
      } catch (e) {
      }
    }

    function psLiteral(value) {
      return "'" + String(value).replace(/'/g, "''") + "'";
    }

    function winQuote(value) {
      return '"' + String(value).replace(/"/g, '""') + '"';
    }

    function tempPath(name) {
      return fso.BuildPath(envOr("TEMP", fso.GetSpecialFolder(2).Path), name);
    }

    function writeUtf16File(path, text) {
      var file = fso.CreateTextFile(path, true, true);
      file.Write(text);
      file.Close();
    }

    function readAsciiFile(path) {
      var file = fso.OpenTextFile(path, 1, false);
      var text = file.ReadAll();
      file.Close();
      return text;
    }

    function powerShellExePath() {
      var candidate = fso.BuildPath(systemRoot, "System32\\WindowsPowerShell\\v1.0\\powershell.exe");
      if (fso.FileExists(candidate)) return candidate;
      return "powershell.exe";
    }

    function buildPowerShellCommand(scriptPath, resultPath, action, enable, openAfter) {
      var lines = [];
      lines.push("$ErrorActionPreference='Stop'");
      lines.push("$runtime=" + psLiteral(scriptPath));
      lines.push("$result=" + psLiteral(resultPath));
      lines.push("$action=" + psLiteral(action));
      lines.push("$enableText=" + psLiteral(enable ? "true" : "false"));
      lines.push("$openAfterText=" + psLiteral(openAfter ? "true" : "false"));
      lines.push("function __w([string]$Message){try{$safe=([string]$Message)-replace '[\\r\\n]+',' ';$content='status=ERROR'+[Environment]::NewLine+'fast=False'+[Environment]::NewLine+'message='+$safe;[System.IO.File]::WriteAllText($result,$content,[System.Text.Encoding]::ASCII)}catch{}}");
      lines.push("try{if($enableText -eq 'true'){$enableBool=$true}else{$enableBool=$false};if($openAfterText -eq 'true'){$openAfterBool=$true}else{$openAfterBool=$false};$text=[System.IO.File]::ReadAllText($runtime,[System.Text.Encoding]::Unicode);$script=[ScriptBlock]::Create($text);& $script -Action $action -Enable:$enableBool -OpenAfter:$openAfterBool;if(-not(Test-Path -LiteralPath $result)){__w 'Runtime finished without writing a result file.';exit 2};exit 0}catch{__w $_.Exception.Message;exit 1}");
      return winQuote(powerShellExePath()) +
        " -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command " +
        winQuote(lines.join("; "));
    }

    function buildRuntimePowerShell() {
      var lines = [];
      lines.push("param([string]$Action = 'Status', [bool]$Enable = $false, [bool]$OpenAfter = $true)");
      lines.push("$ErrorActionPreference = 'Stop'");
      lines.push("$CodexHome = " + psLiteral(codexHome));
      lines.push("$CodexExeOverride = " + psLiteral(codexExeOverride));
      lines.push("$LocalAppData = " + psLiteral(localAppData));
      lines.push("$ProgramFiles = " + psLiteral(programFiles));
      lines.push("$ProgramFilesX86 = " + psLiteral(programFilesX86));
      lines.push("$ResultPath = " + psLiteral(tempPath("CodexFastToggle.result.txt")));
      lines.push("$IconPath = " + psLiteral(tempPath("CodexFastToggle.ico")));
      lines.push("$IconBase64 = " + psLiteral(windowIconBase64));
      lines.push("$Utf8NoBom = New-Object -TypeName System.Text.UTF8Encoding -ArgumentList $false");
      lines.push("$StatePath = Join-Path $CodexHome '.codex-global-state.json'");
      lines.push("$StateBackupPath = Join-Path $CodexHome '.codex-global-state.json.bak'");
      lines.push("$BackupDir = Join-Path $CodexHome 'fast-toggle-backups'");
      lines.push("function Write-Result([string]$Status, [bool]$Fast, [string]$Message) {");
      lines.push("  $safe = ($Message -replace '[\\r\\n]+', ' ')");
      lines.push("  $content = \"status=$Status`nfast=$Fast`nmessage=$safe\"");
      lines.push("  [System.IO.File]::WriteAllText($ResultPath, $content, [System.Text.Encoding]::ASCII)");
      lines.push("}");
      lines.push("function Read-State([string]$Path) {");
      lines.push("  if (Test-Path -LiteralPath $Path) { return [System.IO.File]::ReadAllText($Path, [System.Text.Encoding]::UTF8) }");
      lines.push("  return '{\"electron-persisted-atom-state\":{}}'");
      lines.push("}");
      lines.push("function Write-State([string]$Path, [string]$Text) {");
      lines.push("  $dir = Split-Path -Parent $Path");
      lines.push("  if ($dir -and -not (Test-Path -LiteralPath $dir)) { [System.IO.Directory]::CreateDirectory($dir) | Out-Null }");
      lines.push("  [System.IO.File]::WriteAllText($Path, $Text, $Utf8NoBom)");
      lines.push("}");
      lines.push("function Get-AtomRange([string]$Text) {");
      lines.push("  $m = [System.Text.RegularExpressions.Regex]::Match($Text, '\"electron-persisted-atom-state\"\\s*:\\s*\\{')");
      lines.push("  if (-not $m.Success) { return @{ Found = $false; Open = -1; Close = -1 } }");
      lines.push("  $open = $m.Index + $m.Length - 1");
      lines.push("  $i = $open + 1");
      lines.push("  $depth = 0");
      lines.push("  $inString = $false");
      lines.push("  $escape = $false");
      lines.push("  while ($i -lt $Text.Length) {");
      lines.push("    $ch = $Text[$i]");
      lines.push("    if ($inString) {");
      lines.push("      if ($escape) { $escape = $false; $i++; continue }");
      lines.push("      if ($ch -eq '\\') { $escape = $true; $i++; continue }");
      lines.push("      if ($ch -eq '\"') { $inString = $false }");
      lines.push("      $i++; continue");
      lines.push("    }");
      lines.push("    if ($ch -eq '\"') { $inString = $true; $i++; continue }");
      lines.push("    if ($ch -eq '{' -or $ch -eq '[') { $depth++; $i++; continue }");
      lines.push("    if ($ch -eq '}' -or $ch -eq ']') {");
      lines.push("      if ($ch -eq '}' -and $depth -eq 0) { return @{ Found = $true; Open = $open; Close = $i } }");
      lines.push("      if ($depth -gt 0) { $depth-- }");
      lines.push("      $i++; continue");
      lines.push("    }");
      lines.push("    $i++");
      lines.push("  }");
      lines.push("  return @{ Found = $false; Open = $open; Close = -1 }");
      lines.push("}");
      lines.push("function Get-JsonValueEnd([string]$Text, [int]$Start, [int]$Limit) {");
      lines.push("  $i = $Start");
      lines.push("  while ($i -lt $Limit -and [char]::IsWhiteSpace($Text[$i])) { $i++ }");
      lines.push("  if ($i -ge $Limit) { return $i }");
      lines.push("  $ch = $Text[$i]");
      lines.push("  if ($ch -eq '\"') {");
      lines.push("    $i++");
      lines.push("    $escape = $false");
      lines.push("    while ($i -lt $Limit) {");
      lines.push("      $v = $Text[$i]");
      lines.push("      if ($escape) { $escape = $false; $i++; continue }");
      lines.push("      if ($v -eq '\\') { $escape = $true; $i++; continue }");
      lines.push("      if ($v -eq '\"') { return ($i + 1) }");
      lines.push("      $i++");
      lines.push("    }");
      lines.push("    return $i");
      lines.push("  }");
      lines.push("  if ($ch -eq '{' -or $ch -eq '[') {");
      lines.push("    $depth = 0");
      lines.push("    $inString = $false");
      lines.push("    $escape = $false");
      lines.push("    while ($i -lt $Limit) {");
      lines.push("      $v = $Text[$i]");
      lines.push("      if ($inString) {");
      lines.push("        if ($escape) { $escape = $false; $i++; continue }");
      lines.push("        if ($v -eq '\\') { $escape = $true; $i++; continue }");
      lines.push("        if ($v -eq '\"') { $inString = $false }");
      lines.push("        $i++; continue");
      lines.push("      }");
      lines.push("      if ($v -eq '\"') { $inString = $true; $i++; continue }");
      lines.push("      if ($v -eq '{' -or $v -eq '[') { $depth++; $i++; continue }");
      lines.push("      if ($v -eq '}' -or $v -eq ']') {");
      lines.push("        if ($depth -gt 0) { $depth-- }");
      lines.push("        $i++");
      lines.push("        if ($depth -eq 0) { return $i }");
      lines.push("        continue");
      lines.push("      }");
      lines.push("      $i++");
      lines.push("    }");
      lines.push("    return $i");
      lines.push("  }");
      lines.push("  while ($i -lt $Limit -and $Text[$i] -ne ',') { $i++ }");
      lines.push("  while ($i -gt $Start -and [char]::IsWhiteSpace($Text[$i - 1])) { $i-- }");
      lines.push("  return $i");
      lines.push("}");
      lines.push("function Find-TopLevelAtomFieldRange([string]$Text, [string]$Name) {");
      lines.push("  $atom = Get-AtomRange $Text");
      lines.push("  if (-not $atom.Found) { return @{ Found = $false; Atom = $atom } }");
      lines.push("  $start = $atom.Open + 1");
      lines.push("  $limit = $atom.Close");
      lines.push("  $target = '\"' + $Name + '\"'");
      lines.push("  $i = $start");
      lines.push("  $depth = 0");
      lines.push("  $inString = $false");
      lines.push("  $escape = $false");
      lines.push("  while ($i -lt $limit) {");
      lines.push("    $ch = $Text[$i]");
      lines.push("    if ($inString) {");
      lines.push("      if ($escape) { $escape = $false; $i++; continue }");
      lines.push("      if ($ch -eq '\\') { $escape = $true; $i++; continue }");
      lines.push("      if ($ch -eq '\"') { $inString = $false }");
      lines.push("      $i++; continue");
      lines.push("    }");
      lines.push("    if ($ch -eq '\"') {");
      lines.push("      if ($depth -eq 0 -and $i + $target.Length -le $limit -and $Text.Substring($i, $target.Length) -eq $target) {");
      lines.push("        $j = $i + $target.Length");
      lines.push("        while ($j -lt $limit -and [char]::IsWhiteSpace($Text[$j])) { $j++ }");
      lines.push("        if ($j -lt $limit -and $Text[$j] -eq ':') {");
      lines.push("          $valueStart = $j + 1");
      lines.push("          $valueEnd = Get-JsonValueEnd $Text $valueStart $limit");
      lines.push("          $removeStart = $i");
      lines.push("          $removeEnd = $valueEnd");
      lines.push("          $k = $valueEnd");
      lines.push("          while ($k -lt $limit -and [char]::IsWhiteSpace($Text[$k])) { $k++ }");
      lines.push("          if ($k -lt $limit -and $Text[$k] -eq ',') {");
      lines.push("            $removeEnd = $k + 1");
      lines.push("          } else {");
      lines.push("            $k = $i - 1");
      lines.push("            while ($k -ge $start -and [char]::IsWhiteSpace($Text[$k])) { $k-- }");
      lines.push("            if ($k -ge $start -and $Text[$k] -eq ',') { $removeStart = $k }");
      lines.push("          }");
      lines.push("          return @{ Found = $true; KeyStart = $i; ValueEnd = $valueEnd; RemoveStart = $removeStart; RemoveEnd = $removeEnd; Atom = $atom }");
      lines.push("        }");
      lines.push("      }");
      lines.push("      $inString = $true; $i++; continue");
      lines.push("    }");
      lines.push("    if ($ch -eq '{' -or $ch -eq '[') { $depth++; $i++; continue }");
      lines.push("    if ($ch -eq '}' -or $ch -eq ']') { if ($depth -gt 0) { $depth-- }; $i++; continue }");
      lines.push("    $i++");
      lines.push("  }");
      lines.push("  return @{ Found = $false; Atom = $atom }");
      lines.push("}");
      lines.push("function Add-AtomField([string]$Text, [string]$Field) {");
      lines.push("  $atom = Get-AtomRange $Text");
      lines.push("  if (-not $atom.Found) { return '{\"electron-persisted-atom-state\":{' + $Field + '}}' }");
      lines.push("  $insertAt = $atom.Open + 1");
      lines.push("  $tail = $Text.Substring($insertAt, $atom.Close - $insertAt)");
      lines.push("  $insert = $Field");
      lines.push("  if ($tail -notmatch '^\\s*$') { $insert += ',' }");
      lines.push("  return $Text.Substring(0, $insertAt) + $insert + $Text.Substring($insertAt)");
      lines.push("}");
      lines.push("function Set-StringField([string]$Text, [string]$Name, [string]$Value) {");
      lines.push("  $replacement = '\"' + $Name + '\":\"' + $Value + '\"'");
      lines.push("  $field = Find-TopLevelAtomFieldRange $Text $Name");
      lines.push("  if ($field.Found) { return $Text.Substring(0, $field.KeyStart) + $replacement + $Text.Substring($field.ValueEnd) }");
      lines.push("  return Add-AtomField $Text $replacement");
      lines.push("}");
      lines.push("function Set-BoolField([string]$Text, [string]$Name, [bool]$Value) {");
      lines.push("  if ($Value) { $boolText = 'true' } else { $boolText = 'false' }");
      lines.push("  $replacement = '\"' + $Name + '\":' + $boolText");
      lines.push("  $field = Find-TopLevelAtomFieldRange $Text $Name");
      lines.push("  if ($field.Found) { return $Text.Substring(0, $field.KeyStart) + $replacement + $Text.Substring($field.ValueEnd) }");
      lines.push("  return Add-AtomField $Text $replacement");
      lines.push("}");
      lines.push("function Remove-Field([string]$Text, [string]$Name) {");
      lines.push("  $field = Find-TopLevelAtomFieldRange $Text $Name");
      lines.push("  if ($field.Found) { return $Text.Substring(0, $field.RemoveStart) + $Text.Substring($field.RemoveEnd) }");
      lines.push("  return $Text");
      lines.push("}");
      lines.push("function Get-TopLevelAtomStringField([string]$Text, [string]$Name) {");
      lines.push("  $m = [System.Text.RegularExpressions.Regex]::Match($Text, '\"electron-persisted-atom-state\"\\s*:\\s*\\{')");
      lines.push("  if (-not $m.Success) { return $null }");
      lines.push("  $i = $m.Index + $m.Length");
      lines.push("  $target = '\"' + $Name + '\"'");
      lines.push("  $depth = 0");
      lines.push("  $inString = $false");
      lines.push("  $escape = $false");
      lines.push("  while ($i -lt $Text.Length) {");
      lines.push("    $ch = $Text[$i]");
      lines.push("    if ($inString) {");
      lines.push("      if ($escape) { $escape = $false; $i++; continue }");
      lines.push("      if ($ch -eq '\\') { $escape = $true; $i++; continue }");
      lines.push("      if ($ch -eq '\"') { $inString = $false }");
      lines.push("      $i++; continue");
      lines.push("    }");
      lines.push("    if ($ch -eq '\"') {");
      lines.push("      if ($depth -eq 0 -and $i + $target.Length -le $Text.Length -and $Text.Substring($i, $target.Length) -eq $target) {");
      lines.push("        $j = $i + $target.Length");
      lines.push("        while ($j -lt $Text.Length -and [char]::IsWhiteSpace($Text[$j])) { $j++ }");
      lines.push("        if ($j -lt $Text.Length -and $Text[$j] -eq ':') {");
      lines.push("          $j++");
      lines.push("          while ($j -lt $Text.Length -and [char]::IsWhiteSpace($Text[$j])) { $j++ }");
      lines.push("          if ($j -lt $Text.Length -and $Text[$j] -eq '\"') {");
      lines.push("            $j++");
      lines.push("            $value = ''");
      lines.push("            $valueEscape = $false");
      lines.push("            while ($j -lt $Text.Length) {");
      lines.push("              $v = $Text[$j]");
      lines.push("              if ($valueEscape) { $value += $v; $valueEscape = $false; $j++; continue }");
      lines.push("              if ($v -eq '\\') { $valueEscape = $true; $j++; continue }");
      lines.push("              if ($v -eq '\"') { return $value }");
      lines.push("              $value += $v");
      lines.push("              $j++");
      lines.push("            }");
      lines.push("          }");
      lines.push("        }");
      lines.push("      }");
      lines.push("      $inString = $true; $i++; continue");
      lines.push("    }");
      lines.push("    if ($ch -eq '{' -or $ch -eq '[') { $depth++; $i++; continue }");
      lines.push("    if ($ch -eq '}' -or $ch -eq ']') {");
      lines.push("      if ($ch -eq '}' -and $depth -eq 0) { return $null }");
      lines.push("      if ($depth -gt 0) { $depth-- }");
      lines.push("      $i++; continue");
      lines.push("    }");
      lines.push("    $i++");
      lines.push("  }");
      lines.push("  return $null");
      lines.push("}");
      lines.push("function Test-FastPath([string]$Path) {");
      lines.push("  $value = Get-TopLevelAtomStringField (Read-State $Path) 'default-service-tier'");
      lines.push("  return ($value -eq 'fast')");
      lines.push("}");
      lines.push("function Get-FastValuePath([string]$Path) {");
      lines.push("  $value = Get-TopLevelAtomStringField (Read-State $Path) 'default-service-tier'");
      lines.push("  if ($null -eq $value -or $value -eq '') { return '<missing>' }");
      lines.push("  return $value");
      lines.push("}");
      lines.push("function Test-Fast {");
      lines.push("  return (Test-FastPath $StatePath)");
      lines.push("}");
      lines.push("function Get-StateSummary {");
      lines.push("  return ('main=' + (Get-FastValuePath $StatePath) + '; bak=' + (Get-FastValuePath $StateBackupPath) + '; home=' + $CodexHome)");
      lines.push("}");
      lines.push("function Rewrite-FastState([string]$Path, [bool]$On) {");
      lines.push("  $text = Read-State $Path");
      lines.push("  if ($On) {");
      lines.push("    $text = Set-BoolField $text 'has-user-changed-service-tier' $true");
      lines.push("    $text = Set-StringField $text 'default-service-tier' 'fast'");
      lines.push("    $text = Set-BoolField $text 'has-seen-fast-mode-announcement' $true");
      lines.push("  } else {");
      lines.push("    $text = Remove-Field $text 'has-user-changed-service-tier'");
      lines.push("    $text = Remove-Field $text 'default-service-tier'");
      lines.push("    $text = Remove-Field $text 'has-seen-fast-mode-announcement'");
      lines.push("  }");
      lines.push("  Write-State $Path $text");
      lines.push("}");
      lines.push("function Backup-File([string]$Path) {");
      lines.push("  if (-not (Test-Path -LiteralPath $Path)) { return }");
      lines.push("  if (-not (Test-Path -LiteralPath $BackupDir)) { [System.IO.Directory]::CreateDirectory($BackupDir) | Out-Null }");
      lines.push("  $dest = Join-Path $BackupDir ((Split-Path -Leaf $Path) + '.' + (Get-Date -Format 'yyyyMMdd-HHmmss'))");
      lines.push("  Copy-Item -LiteralPath $Path -Destination $dest -Force");
      lines.push("}");
      lines.push("function Test-DesktopExe([string]$Path) {");
      lines.push("  if ([string]::IsNullOrWhiteSpace($Path) -or -not (Test-Path -LiteralPath $Path)) { return $false }");
      lines.push("  $dir = Split-Path -Parent $Path");
      lines.push("  return (Test-Path -LiteralPath (Join-Path $dir 'resources\\app.asar'))");
      lines.push("}");
      lines.push("function Find-DesktopCodexExe {");
      lines.push("  if (Test-DesktopExe $CodexExeOverride) { return $CodexExeOverride }");
      lines.push("  $candidates = @(");
      lines.push("    (Join-Path $LocalAppData 'Programs\\Codex\\Codex.exe'),");
      lines.push("    (Join-Path $LocalAppData 'Codex\\Codex.exe'),");
      lines.push("    (Join-Path $ProgramFiles 'Programs\\Codex\\Codex.exe'),");
      lines.push("    (Join-Path $ProgramFiles 'Codex\\Codex.exe'),");
      lines.push("    (Join-Path $ProgramFilesX86 'Programs\\Codex\\Codex.exe'),");
      lines.push("    (Join-Path $ProgramFilesX86 'Codex\\Codex.exe')");
      lines.push("  )");
      lines.push("  foreach ($candidate in $candidates) { if (Test-DesktopExe $candidate) { return $candidate } }");
      lines.push("  foreach ($dir in ($candidates | ForEach-Object { Split-Path -Parent $_ } | Select-Object -Unique)) {");
      lines.push("    if (Test-Path -LiteralPath $dir) {");
      lines.push("      foreach ($exe in Get-ChildItem -LiteralPath $dir -Filter '*.exe' -ErrorAction SilentlyContinue) {");
      lines.push("        if ($exe.Name -notmatch '^(Update|Squirrel)\\.exe$' -and (Test-DesktopExe $exe.FullName)) { return $exe.FullName }");
      lines.push("      }");
      lines.push("    }");
      lines.push("  }");
      lines.push("  return ''");
      lines.push("}");
      lines.push("function Stop-Codex {");
      lines.push("  Get-Process -ErrorAction SilentlyContinue | ForEach-Object {");
      lines.push("    try { $path = $_.Path } catch { $path = $null }");
      lines.push("    if ($path -and ([System.IO.Path]::GetFileName($path) -match '(?i)codex') -and (Test-Path -LiteralPath (Join-Path (Split-Path -Parent $path) 'resources\\app.asar'))) {");
      lines.push("      Stop-Process -Id $_.Id -Force -ErrorAction SilentlyContinue");
      lines.push("    }");
      lines.push("  }");
      lines.push("}");
      lines.push("function Open-Codex {");
      lines.push("  if (-not $OpenAfter) { return 'Codex reopen skipped' }");
      lines.push("  $exe = Find-DesktopCodexExe");
      lines.push("  if ($exe) { [System.Diagnostics.Process]::Start($exe) | Out-Null; return 'Opened desktop Codex' }");
      lines.push("  return 'Desktop Codex not found; open manually'");
      lines.push("}");
      lines.push("try {");
      lines.push("  if ($Action -eq 'WriteIcon') { [System.IO.File]::WriteAllBytes($IconPath, [System.Convert]::FromBase64String($IconBase64)); Write-Result 'OK' (Test-Fast) 'Icon ready'; exit 0 }");
      lines.push("  if ($Action -eq 'Status') { Write-Result 'OK' (Test-Fast) ('Ready. ' + (Get-StateSummary)); exit 0 }");
      lines.push("  if ($Action -eq 'Apply') {");
      lines.push("    Stop-Codex");
      lines.push("    Backup-File $StatePath");
      lines.push("    Backup-File $StateBackupPath");
      lines.push("    Rewrite-FastState $StatePath $Enable");
      lines.push("    Rewrite-FastState $StateBackupPath $Enable");
      lines.push("    $fastAfterWrite = Test-Fast");
      lines.push("    $summaryAfterWrite = Get-StateSummary");
      lines.push("    $openMessage = Open-Codex");
      lines.push("    if ($Enable) { $changeMessage = 'Fast enabled. ' } else { $changeMessage = 'Fast disabled. ' }");
      lines.push("    Write-Result 'OK' $fastAfterWrite ($changeMessage + $summaryAfterWrite + '. ' + $openMessage)");
      lines.push("    exit 0");
      lines.push("  }");
      lines.push("  throw ('Unknown action: ' + $Action)");
      lines.push("} catch {");
      lines.push("  try { Write-Result 'ERROR' $false $_.Exception.Message } catch {}");
      lines.push("  exit 1");
      lines.push("}");
      return lines.join("\r\n");
    }

    function parseResult(text) {
      var result = { status: "ERROR", fast: false, message: "" };
      var lines = text.replace(/^\uFEFF/, "").split(/\r?\n/);
      for (var i = 0; i < lines.length; i++) {
        var at = lines[i].indexOf("=");
        if (at < 0) continue;
        var key = lines[i].substring(0, at);
        var value = lines[i].substring(at + 1);
        if (key === "status") result.status = value;
        if (key === "fast") result.fast = /^true$/i.test(value);
        if (key === "message") result.message = value;
      }
      return result;
    }

    function runRuntime(action, enable, openAfter) {
      var scriptPath = tempPath("CodexFastToggle-runtime.ps1");
      var resultPath = tempPath("CodexFastToggle.result.txt");
      writeUtf16File(scriptPath, buildRuntimePowerShell());
      if (fso.FileExists(resultPath)) fso.DeleteFile(resultPath, true);

      var cmd = buildPowerShellCommand(scriptPath, resultPath, action, enable, openAfter);
      var code = shell.Run(cmd, 0, true);
      if (!fso.FileExists(resultPath)) throw new Error("PowerShell did not start or was blocked. Tried: " + powerShellExePath());
      var result = parseResult(readAsciiFile(resultPath));
      if (code !== 0 || result.status !== "OK") throw new Error(result.message || ("PowerShell exited with code " + code));
      return result;
    }

    function isFastOn() {
      return runRuntime("Status", false, false).fast;
    }

    function setStatus(enabled) {
      document.getElementById("statusValue").innerText = enabled ? "ON" : "OFF";
      document.getElementById("statusValue").style.color = enabled ? "#137333" : "#9a3412";
      document.getElementById("toggleButton").innerText = enabled ? "关闭 Fast" : "开启 Fast";
    }

    function setStatusError() {
      document.getElementById("statusValue").innerText = "ERR";
      document.getElementById("statusValue").style.color = "#b42318";
      document.getElementById("toggleButton").innerText = "刷新失败";
    }

    function refreshStatus() {
      try {
        var result = runRuntime("Status", false, false);
        setStatus(result.fast);
        log((result.message || "Status refreshed") + " -> " + (result.fast ? "ON" : "OFF"));
      } catch (e) {
        setStatusError();
        log("ERROR: " + e.message);
      }
    }

    function applyFast(enable) {
      try {
        var result = runRuntime("Apply", enable, document.getElementById("openAfter").checked);
        setStatus(result.fast);
        log(result.message || (enable ? "Fast enabled" : "Fast disabled"));
      } catch (e) {
        setStatusError();
        log("ERROR: " + e.message);
        alert("操作失败: " + e.message);
      }
    }

    function toggleFast() {
      applyFast(!isFastOn());
    }

    window.onload = function() {
      setupIcons();
      refreshStatus();
      log("Ready");
    };
  </script>
</head>
<body>
  <div class="wrap">
    <div class="hero">
      <div class="header">
        <img id="appIcon" class="appIcon" alt="">
        <div>
          <h1>Codex Fast Toggle</h1>
          <div class="sub">Fast Mode switch for desktop Codex</div>
        </div>
      </div>
      <div class="status">
        <span>Fast Mode</span>
        <strong id="statusValue">...</strong>
      </div>
      <div class="row">
        <button id="toggleButton" class="primary" onclick="toggleFast()">切换</button>
        <button onclick="applyFast(true)">开启</button>
        <button onclick="applyFast(false)">关闭</button>
        <button onclick="refreshStatus()">刷新</button>
      </div>
      <label>
        <input id="openAfter" type="checkbox" checked>
        切换后重新打开桌面版 Codex
      </label>
    </div>
    <pre id="log"></pre>
  </div>
</body>
</html>
